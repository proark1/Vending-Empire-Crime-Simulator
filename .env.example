# Backend API
PORT=3000
DATABASE_URL=postgres://vendetta:vendetta@127.0.0.1:5432/vendetta_vending
PGSSLMODE=disable

# Admin login seed — REQUIRED in production. When unset in production the server
# refuses to seed an admin account (there is no public default). Locally, a
# dev-only fallback is used so `npm start` works without configuration.
# Use a long, random PIN; never commit a real one.
ADMIN_NAME=change-me
ADMIN_PIN=change-me-to-a-long-random-pin

# Session and payload limits
SESSION_DAYS=14
JSON_LIMIT_BYTES=8388608

# Multiplayer relay
MULTIPLAYER_ROOM_MAX_PEERS=4

{
  "name": "vendetta-vending",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20 <25",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "check:perf": "node scripts/check-performance-budgets.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "smoke:server": "node scripts/smoke-production-server.mjs",
    "start": "node server.js",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -b",
    "verify": "npm run typecheck && npm test && npm run build && npm run check:perf && npm run smoke:server && npm run lint",
    "lint": "eslint ."
  },
  "dependencies": {
    "immer": "^11.1.9",
    "lucide-react": "^0.468.0",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.171.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.171.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^6.0.1",
    "vitest": "^4.1.9"
  }
}
